@{
    ViewData["Title"] = "Support Request";
}

<div class="container mt-5" style="max-width: 600px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["SuccessMessage"]
        </div>
    }

    <!-- Support request form -->
    <div class="card shadow-sm">
        <div class="card-body">

            <h3 class="text-center mb-4">Support Request 🛠️</h3>

            <form method="post" action="/Home/SupportRequest">

                <!-- Support subject -->
                <div class="mb-3">
                    <label class="form-label">Subject</label>
                    <input type="text" name="subject" class="form-control" placeholder="Enter subject" required/>
                </div>

                <!-- Support message -->
                <div class="mb-3">
                    <label class="form-label">Message</label>
                    <textarea name="message" class="form-control" rows="4" placeholder="Write your message..." required></textarea>
                </div>

                <!-- Submit button -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Submit Request</button>
                </div>

            </form>

            <!-- Success message -->
            @if (ViewBag.Message != null)
            {
                <div class="alert alert-success mt-3 text-center">
                    @ViewBag.Message
                </div>
            }

        </div>
    </div>

</div>