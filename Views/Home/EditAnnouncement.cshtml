@model CampusConnect.Models.Announcement

@{
    ViewData["Title"] = "Edit Announcement";
}

<div class="container mt-5" style="max-width: 600px;">

    <div class="card shadow-sm">
        <div class="card-body">

            <h3 class="text-center mb-4">Edit Announcement ✏️</h3>

            <form method="post" action="/Home/EditAnnouncement">

                <input type="hidden" name="id" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" name="title" class="form-control" value="@Model.Title" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Content</label>
                    <textarea name="content" class="form-control" rows="4" required>@Model.Content</textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning">Update Announcement</button>
                    <a href="/Home/AdminDashboard" class="btn btn-secondary">Cancel</a>
                </div>

            </form>

        </div>
    </div>

</div>