@model CampusConnect.Models.Event

@{
    ViewData["Title"] = "Edit Event";
}

<div class="container mt-4">

    <!-- Edit event heading -->
    <h2>Edit Event</h2>

    <form method="post" action="/Home/EditEvent">

        <!-- Hidden event id -->
        <input type="hidden" name="id" value="@Model.Id" />

        <!-- Event title -->
        <div class="mb-3">
            <label>Title</label>
            <input class="form-control" type="text" name="title" value="@Model.Title" />
        </div>

        <!-- Event description -->
        <div class="mb-3">
            <label>Description</label>
            <input class="form-control" type="text" name="description" value="@Model.Description" />
        </div>

        <!-- Event date -->
        <div class="mb-3">
            <label>Date</label>
            <input class="form-control" type="date" name="eventDate" value="@Model.EventDate.ToString("yyyy-MM-dd")" />
        </div>

        <!-- Venue dropdown -->
        <div class="mb-3">
            <label>Venue</label>
            <select class="form-control" name="venueId">
                @foreach (var v in ViewBag.Venues)
                {
                    if (v.Id == Model.VenueId)
                    {
                        <option value="@v.Id" selected>@v.VenueName</option>
                    }
                    else
                    {
                        <option value="@v.Id">@v.VenueName</option>
                    }
                }
            </select>
        </div>

        <!-- Update and cancel buttons -->
        <button class="btn btn-success" type="submit">Update Event</button>
        <a href="/Home/AdminDashboard" class="btn btn-secondary">Cancel</a>

    </form>
</div>