@model List<CampusConnect.Models.Event>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">

    <!-- Admin page heading -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Admin Dashboard ⚙️</h2>
            <p class="text-muted">Welcome Admin</p>
        </div>

        <a href="/Home/Logout" class="btn btn-dark">Logout</a>
    </div>

    <!-- Admin action buttons -->
    <div class="mb-4">
        <a href="/Home/CreateEvent" class="btn btn-primary me-2">Create New Event</a>
        <a href="/Home/CreateAnnouncement" class="btn btn-dark">Create Announcement</a>
    </div>

    <!-- Announcements section -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h3 class="card-title">Announcements</h3>

            @if (ViewBag.Announcements == null || ViewBag.Announcements.Count == 0)
            {
                <p class="text-muted">No announcements yet.</p>
            }
            else
            {
                foreach (var a in ViewBag.Announcements)
                {
                    <div class="card mb-3 shadow-sm">
                        <div class="card-body">
                            <h5 class="fw-bold">@a.Title</h5>
                            <p>@a.Content</p>
                            <small class="text-muted">@a.DatePosted.ToString("dd MMM yyyy HH:mm")</small>

                            <div class="mt-3">
                                <a href="/Home/EditAnnouncement/@a.Id" class="btn btn-warning btn-sm me-2">Edit</a>

                                <form method="post" action="/Home/DeleteAnnouncement" style="display:inline;">
                                    <input type="hidden" name="announcementId" value="@a.Id" />
                                    <button class="btn btn-danger btn-sm" type="submit"
                                            onclick="return confirm('Are you sure you want to delete this announcement?')">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Events section -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h3 class="card-title">Events</h3>

            @foreach (var e in Model)
            {
                <div class="border-bottom pb-3 mb-3">
                    <h5>@e.Title</h5>
                    <p>@e.Description</p>
                    <p><strong>Date:</strong> @e.EventDate.ToString("dd MMM yyyy")</p>
                    <p><strong>Venue:</strong> @e.Venue.VenueName</p>

                    @if (e.Registrations != null && e.Registrations.Count > 0)
                    {
                        <!-- Registered students for this event -->
                        <div class="mt-3">
                            <strong>Registered Students:</strong>
                            <ul class="mt-2">
                                @foreach (var r in e.Registrations)
                                {
                                    <li>
                                        @r.Student.FirstName @r.Student.LastName - @r.Student.Email
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No students registered yet.</p>
                    }

                    <!-- Event edit and delete buttons -->
                    <div class="mt-3">
                        <a href="/Home/EditEvent/@e.Id" class="btn btn-warning btn-sm me-2">Edit</a>

                        <form method="post" action="/Home/DeleteEvent" style="display:inline;">
                            <input type="hidden" name="eventId" value="@e.Id" />
                            <button class="btn btn-danger btn-sm" type="submit"
                                    onclick="return confirm('Are you sure you want to delete this event?')">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

</div>